{
  "name": "User",
  "displayName": { "ja": "ユーザー", "en": "User" },
  "titleIndex": "name",
  "options": { "timestamps": true, "authenticatable": true },
  "properties": {
    "name": {
      "type": "String",
      "displayName": { "ja": "氏名", "en": "Name" },
      "required": true
    },
    "email": {
      "type": "Email",
      "unique": true,
      "displayName": { "ja": "メール", "en": "Email" },
      "required": true
    },
    "role": {
      "type": "EnumRef",
      "enum": "UserRole",
      "displayName": { "ja": "権限", "en": "Role" },
      "default": "sales"
    },
    "createdAt": {
      "type": "Timestamp",
      "displayName": { "ja": "作成日時", "en": "Created At" }
    }
  }
}
