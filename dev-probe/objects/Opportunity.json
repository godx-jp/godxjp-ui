{
  "name": "Opportunity",
  "displayName": { "ja": "商談", "en": "Opportunity" },
  "titleIndex": "name",
  "options": { "timestamps": true },
  "properties": {
    "name": {
      "type": "String",
      "displayName": { "ja": "商談名", "en": "Name" },
      "required": true
    },
    "account": {
      "type": "Association",
      "relation": "ManyToOne",
      "target": "Account",
      "displayName": { "ja": "取引先", "en": "Account" }
    },
    "stage": {
      "type": "EnumRef",
      "enum": "OpportunityStage",
      "displayName": { "ja": "ステージ", "en": "Stage" },
      "default": "prospecting"
    },
    "amount": {
      "type": "Decimal",
      "displayName": { "ja": "金額", "en": "Amount" },
      "precision": 14,
      "scale": 2
    },
    "closeDate": {
      "type": "Date",
      "displayName": { "ja": "完了予定日", "en": "Close Date" }
    },
    "owner": {
      "type": "Association",
      "relation": "ManyToOne",
      "target": "User",
      "displayName": { "ja": "所有者", "en": "Owner" }
    },
    "createdAt": {
      "type": "Timestamp",
      "displayName": { "ja": "作成日時", "en": "Created At" }
    }
  }
}
