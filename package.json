{
  "name": "@godxjp/ui",
  "version": "0.1.0",
  "description": "GoDX Forge unified design system — tokens, primitives, i18n, hooks shared across every service frontend (admin-platform, forge-service, console-service, me-service, agent-service, knowledge-service, …). Source of truth for design language per Plan #19/#22.",
  "private": true,
  "type": "module",
  "sideEffects": [
    "src/tokens/*.css"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./tokens": "./src/tokens/index.css",
    "./tokens.css": "./src/tokens/tokens.css",
    "./tokens-ext.css": "./src/tokens/tokens-ext.css",
    "./i18n": {
      "types": "./src/i18n/index.ts",
      "default": "./src/i18n/index.ts"
    },
    "./hooks": {
      "types": "./src/hooks/index.ts",
      "default": "./src/hooks/index.ts"
    },
    "./data": {
      "types": "./src/data/index.ts",
      "default": "./src/data/index.ts"
    },
    "./primitives": {
      "types": "./src/primitives/index.ts",
      "default": "./src/primitives/index.ts"
    },
    "./components/shell": {
      "types": "./src/components/shell/index.ts",
      "default": "./src/components/shell/index.ts"
    },
    "./components/screens": {
      "types": "./src/components/screens/index.ts",
      "default": "./src/components/screens/index.ts"
    }
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-dropdown-menu": "^2.1.7",
    "@radix-ui/react-label": "^2.1.3",
    "@radix-ui/react-popover": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.2.4",
    "@radix-ui/react-select": "^2.1.7",
    "@radix-ui/react-separator": "^1.1.3",
    "@radix-ui/react-slot": "^1.1.3",
    "@radix-ui/react-switch": "^1.1.4",
    "@radix-ui/react-tabs": "^1.1.4",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@radix-ui/react-visually-hidden": "^1.1.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "i18next": "^23.16.0",
    "i18next-browser-languagedetector": "^8.0.0",
    "lucide-react": "^0.479.0",
    "react-i18next": "^15.1.0",
    "tailwind-merge": "^3.0.0"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "tailwindcss": "^4"
  }
}
