{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "rootDir": "src",
    "resolveJsonModule": true
  },
  "include": ["src"],
  "exclude": [
    "src/**/__tests__/**",
    "src/**/__fixtures__/**",
    "src/**/*.test.*",
    "src/test/**"
  ]
}
