# Pre-commit gate for @godxjp/ui — fails fast on any drift.
#
# Per cardinal rule 12, `--no-verify` is forbidden. If a check below
# fails, FIX the underlying issue (don't bypass).
#
# Order is cheapest → most expensive:
#   1. Token catalogue drift / WCAG / vocabulary lint (~1s).
#   2. Stories ↔ primitives barrel parity (rule 17, ~50ms).
#   3. Docs ↔ primitives parity, advisory missing (rule 18, ~50ms).
#   4. Skill mirror parity .claude/ ↔ .codex/ (rule sync, ~50ms).
#   5. TypeScript strict (~5s).
#
# Storybook play tests + visual snapshots are NOT in this gate (they
# need a browser + Playwright — too slow for pre-commit). Run them
# locally via `pnpm test:stories` before opening a PR; CI re-runs them
# as a blocking gate.

set -e

echo "→ lint:tokens"
pnpm run lint:tokens

echo "→ check:stories-parity"
node scripts/check-stories-parity.mjs

echo "→ check:docs-parity"
node scripts/check-docs-parity.mjs

echo "→ sync:skills (parity check, no rewrite)"
pnpm run sync:skills

echo "→ type-check"
pnpm run type-check

echo "✓ pre-commit gate passed"
